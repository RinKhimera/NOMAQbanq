NEXT_PUBLIC_CONVEX_SITE_URL=

# =====================
# Clerk Authentication
# =====================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Routes de redirection Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard/onboarding

# =====================
# Stripe (Paiements)
# =====================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =====================
# Bunny CDN (Médias)
# =====================
BUNNY_STORAGE_ZONE_NAME=
BUNNY_STORAGE_API_KEY=
BUNNY_CDN_HOSTNAME=

# =====================
# Sentry (Monitoring)
# =====================
SENTRY_AUTH_TOKEN=

# =====================
# App
# =====================
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =====================
# AWS SES (Emails transactionnels)
# =====================
SES_REGION=us-east-2
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
EMAIL_FROM=NOMAQbanq <noreply@nomaqbanq.ca>
SES_CONFIGURATION_SET=
# Sandbox uniquement : redirige TOUS les envois vers cette adresse vérifiée. Vider en prod.
EMAIL_OVERRIDE_TO=
# Prod Vercel uniquement : ARN du rôle IAM assumé via OIDC (identifiants temporaires, pas de
# clés statiques). À définir dans les env vars du projet Vercel, PAS en local. Penser aussi à
# fixer AWS_REGION dans Vercel (il est instable par défaut en multi-région).
AWS_ROLE_ARN=

# =====================================================================
# NOMAQbanq — Variables d'environnement (exemple)
# Copier vers .env.local et remplir. NE JAMAIS committer .env.local.
#
# « Requis » = l'app refuse de démarrer sans (validé par lib/env/schema.ts).
# Les autres sont optionnelles au boot : le code lève une erreur claire à
# l'usage si la fonctionnalité concernée est appelée sans sa config.
# =====================================================================

# =====================
# Base de données — Neon Postgres  (REQUIS)
# =====================
# URL « pooled » (runtime, via PgBouncer) + « unpooled »/directe (migrations Drizzle).
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require

# =====================
# Better Auth  (REQUIS)
# =====================
# Secret de signature des sessions/jetons. >= 32 caractères, UNIQUE par environnement.
# Générer : openssl rand -hex 32   (ou : npx @better-auth/cli secret)
BETTER_AUTH_SECRET=
# Override OPTIONNEL de l'URL d'origine (redirections OAuth, cookies, liens emails).
# En local : http://localhost:3000. Sur Vercel, laisser VIDE → dérivée automatiquement
# (prod → domaine de prod, preview → URL de branche) via lib/base-url.ts.
BETTER_AUTH_URL=http://localhost:3000

# OAuth Google (optionnel — le login Google est désactivé si l'une des deux manque).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =====================
# AWS SES (emails transactionnels)
# =====================
SES_REGION=us-east-2
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
EMAIL_FROM=NOMAQbanq <noreply@nomaqbanq.ca>
# Set de configuration SES (métriques bounces/plaintes). Optionnel.
SES_CONFIGURATION_SET=nomaqbanq-transactional
# DEV/SANDBOX UNIQUEMENT : redirige TOUS les envois vers cette adresse vérifiée
# (sujet préfixé « [DEV → destinataire] »). LAISSER VIDE en preview ET en production.
EMAIL_OVERRIDE_TO=

# =====================
# Stripe (paiements)
# =====================
# ⚠️ Dès que STRIPE_SECRET_KEY est définie, STRIPE_WEBHOOK_SECRET devient OBLIGATOIRE
# (sinon les paiements sont encaissés sans accorder l'accès — garde-fou du schéma).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =====================
# Bunny.net (médias : avatars, images de questions)
# =====================
# Tout-ou-rien : les trois ensemble, ou aucune.
BUNNY_STORAGE_ZONE_NAME=
BUNNY_STORAGE_API_KEY=
BUNNY_CDN_HOSTNAME=
# Hôte CDN public pour l'AFFICHAGE des médias (optionnel, défaut : cdn.nomaqbanq.ca).
NEXT_PUBLIC_BUNNY_CDN_HOSTNAME=

# =====================
# Cron Vercel
# =====================
# Secret partagé que TU génères. Vercel l'envoie en `Authorization: Bearer ${CRON_SECRET}`
# sur les requêtes cron (cf. vercel.json). Sans lui, la route répond 401 (fail-closed).
# Générer : openssl rand -hex 32
CRON_SECRET=

# =====================
# Sentry (monitoring) — build-time
# =====================
# Token d'upload des source maps au build (le DSN est en dur dans la config Sentry).
SENTRY_AUTH_TOKEN=

# =====================
# App
# =====================
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =====================
# Tests E2E (Playwright) — local / CI uniquement
# =====================
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
# Secret protégeant la route /api/e2e (seed/reset des comptes de test).
E2E_RESET_SECRET=
# URL cible des tests E2E (optionnel, défaut http://localhost:3000).
PLAYWRIGHT_BASE_URL=

# =====================
# Tests d'intégration (Vitest + branche Neon éphémère) — CI uniquement
# =====================
INTEGRATION_BRANCH=
INTEGRATION_HOST=
